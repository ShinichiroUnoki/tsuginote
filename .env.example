# Database
DATABASE_URL=postgresql://tsuginote:password@localhost:5433/tsuginote

# Redis
REDIS_URL=redis://localhost:6380

# Auth
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Provider (ollama = ローカルLLM / openai / anthropic)
AI_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama

# Ollama (ローカルLLM — デフォルト、外部APIキー不要)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (オプション — AI_PROVIDER=openai の場合のみ必要)
OPENAI_API_KEY=
# Anthropic (オプション — AI_PROVIDER=anthropic の場合のみ必要)
ANTHROPIC_API_KEY=

# Vector DB
QDRANT_URL=http://localhost:6333

# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
